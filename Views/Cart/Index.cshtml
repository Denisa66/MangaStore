@model List<MangaStoreWeb.Models.Cart>

@{
    ViewData["Title"] = "Shopping Cart";
}

<h2>🛒 Your Shopping Cart</h2>

@if (Model.Count == 0)
{
        <p>Your cart is empty.</p>
}
else
{
        <table class="table">
            <thead>
                <tr>
                    <th>Image</th>
                    <th>Title</th>
                    <th>Price</th>
                    <th>Quantity</th>
                    <th>Total</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                        <tr>
                            <td>
                                <img src="@item.Manga.ImageURL" alt="Manga Cover" width="80" height="100" />
                            </td>
                            <td>@item.Manga.Title</td>
                            <td>@item.Manga.Price Lei</td>
                            <td>
                                <form asp-action="UpdateQuantity" method="post">
                                    <input type="hidden" name="cartId" value="@item.Id" />
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" class="form-control" style="width: 60px; display: inline-block;" />
                                    <button type="submit" class="btn btn-sm btn-primary">✔</button>
                                </form>
                            </td>
                            <td>@(item.Manga.Price * item.Quantity) Lei</td>
                            <td>
                                <a asp-action="RemoveFromCart" asp-route-cartId="@item.Id" class="btn btn-sm btn-danger">🗑️ Remove</a>
                            </td>
                        </tr>
            }
            </tbody>
        </table>

        <div>
            <strong>Total: @(Model.Sum(item => item.Manga.Price * item.Quantity)) Lei</strong>
        </div>

        <form asp-controller="Cart" asp-action="ClearCart" method="post">
            <button class="btn btn-warning">🛒 Clear Cart</button>
        </form>

        <a asp-controller="Checkout" asp-action="Index" class="btn btn-success mt-2">
            ✅ Proceed to Checkout
        </a>
}
