@using Microsoft.AspNetCore.Identity
@inject UserManager<IdentityUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityUser>
@inject UserManager<IdentityUser> UserManager
@inject RoleManager<IdentityRole> RoleManager

@{
    ViewData["Title"] = "Manage Users";
}

<h1>Manage Users</h1>

<table class="table">
    <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    @if (ViewBag.UserRoles.ContainsKey(user.Id))
                    {
                        @string.Join(", ", ViewBag.UserRoles[user.Id])
                    }
                    else
                    {
                        <span>No role</span>
                    }
                </td>
                <td>
                    @if (ViewBag.UserRoles.ContainsKey(user.Id) && ViewBag.UserRoles[user.Id].Contains("Admin"))
                    {
                        <span>Admin (Cannot change)</span>
                    }
                    else
                    {
                        <form asp-action="MakeAdmin" asp-route-id="@user.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-primary">Make Admin</button>
                        </form>

                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
